{
  "configurations": [
    {
      "name": "Server debugger",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app/server/server.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Test Program",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/app/test/test",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/app",
      "environment": [],
      "externalConsole": false,
      "MIMode": "lldb",
    },
    {
      "name": "Python Unit tests",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/app/server",
      "python": "${workspaceFolder}/app/server/env/bin/python"
    },
    {
      "name": "Debug MCU",
      "cwd": "${workspaceFolder}/app",
      "executable": "${workspaceFolder}/app/bin/firmware.elf",
      "request": "launch",
      "servertype": "openocd",
      "type": "cortex-debug",
      "device": "STM32F401RE",
      "runToEntryPoint": "main",
      "interface": "swd",
      "preLaunchTask": "build_debug",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f4x.cfg"
      ],
      "searchDir": [
        "/opt/homebrew/share/openocd/scripts"
      ],
      "gdbPath": "/opt/homebrew/bin/arm-none-eabi-gdb",
      "armToolchainPath": "/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi",
    },
  ]
}