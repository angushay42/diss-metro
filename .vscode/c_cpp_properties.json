{
    "configurations": [
        {
            "name": "Mac",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/app/inc",
                "${workspaceFolder}/FreeRTOS-LTS/FreeRTOS/FreeRTOS-Kernel"

